[Unit]
Description=Deploy the latest CI-approved ani-web master commit
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=oneshot
User=dangphuc
Group=docker
ExecStart=/srv/ani-desk/deployer/pull-deploy.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full
ReadWritePaths=/srv/ani-desk
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

[Install]
WantedBy=multi-user.target
