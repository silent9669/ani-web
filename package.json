{
  "name": "ani-desk",
  "version": "1.0.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config web/vite.config.ts --host 127.0.0.1 --port 1420",
    "build": "tsc -p web/tsconfig.json && vite build --config web/vite.config.ts",
    "preview": "vite preview --config web/vite.config.ts",
    "icons": "node scripts/prepare-icon-source.mjs && tauri icon src-tauri/icons/icon-source.png",
    "check:icons": "node scripts/check-generated-icons.mjs",
    "check:release-version": "node scripts/verify-release-version.mjs",
    "release:manifest": "node scripts/generate-updater-manifest.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "dashjs": "^5.2.0",
    "framer-motion": "^11.0.0",
    "hls.js": "^1.5.0",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.4.5",
    "vite": "^8.0.16"
  }
}
