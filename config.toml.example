# ani-desk configuration file
# Place this file at:
#   macOS: ~/Library/Application Support/com.silent9669.ani-desk/config.toml
#   Windows: %APPDATA%\com.silent9669.ani-desk\config.toml
#   Linux: ~/.config/ani-desk/config.toml

[sources]
# Optional AllAnime source. Search and episode metadata are available, but its
# current stream sources fail playback certification.
allanime = false

# Live-certified English source.
animegg = false

# Signed English-sub series and film streams.
moviebox = true

# Enable KKPhim source (Vietnamese)
kkphim = true

# Enable OPhim source (Vietnamese)
ophim = true

# Legacy duplicate of OPhim. Keep disabled unless testing migration behavior.
animevietsub = false

# Additional documented AniMapper Vietnamese providers. AnimeTVN is not yet
# certified for direct playback. Niniyo is certified through AniMapper's
# mapped episode and HLS source APIs.
animetvn = false
niniyo = true

# Legacy experimental setting retained for compatibility. The runtime ignores
# it until a maintained upstream passes direct playback certification.
hianime = false

[theme]
primary_color = "#FF2934"
secondary_color = "#39C7D5"
