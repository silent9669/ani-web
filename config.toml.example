# ani-desk configuration file
# Place this file at:
#   macOS: ~/Library/Application Support/com.silent9669.ani-desk/config.toml
#   Windows: %APPDATA%\com.silent9669.ani-desk\config.toml
#   Linux: ~/.config/ani-desk/config.toml

[sources]
# Enable AllAnime source (English)
allanime = true

# Direct English hard-sub streams, including anime films.
animegg = true

# Signed English-sub series and film streams.
moviebox = true

# Enable KKPhim source (Vietnamese)
kkphim = true

# Enable OPhim source (Vietnamese)
ophim = true

# Enable AnimeVietSub through the AniMapper streaming API (Vietnamese)
animevietsub = true

# Additional documented AniMapper Vietnamese providers. Runtime health checks
# disable them automatically when mapping or playback is unavailable.
animetvn = false
niniyo = false

# Experimental English source. Disabled until direct playback certification passes.
hianime = false

[theme]
primary_color = "#FF2934"
secondary_color = "#39C7D5"
