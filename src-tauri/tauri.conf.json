{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ani-desk",
  "version": "1.0.3",
  "identifier": "com.silent9669.ani-desk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ani-desk",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "silent9669",
    "homepage": "https://github.com/silent9669/ani-desk",
    "copyright": "Copyright (c) 2026 silent9669",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Entertainment",
    "shortDescription": "Anime streaming desktop app",
    "longDescription": "ani-desk is a Netflix-inspired desktop interface for searching and watching anime from multiple sources.",
    "macOS": {
      "minimumSystemVersion": "15.0",
      "dmg": {
        "background": "../packaging/macos/dmg-background.png",
        "windowSize": {
          "width": 760,
          "height": 420
        },
        "appPosition": {
          "x": 230,
          "y": 205
        },
        "applicationFolderPosition": {
          "x": 540,
          "y": 205
        }
      }
    },
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGMjhBMDkxOTZEREQ2RkYKUldULzF0MldrYUFvTDQ0VTZOZzRMbjN5VDdRTHRlQUYvQnVsbW1tWGRUdUo5eGVwK2o2eWMxM3AK",
      "endpoints": [
        "https://github.com/silent9669/ani-desk/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
