{
  "version": "1.0.0",
  "description": "Desktop app for anime streaming",
  "homepage": "https://github.com/silent9669/ani-desk",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/silent9669/ani-desk/releases/download/v1.0.0/ani-desk_1.0.0_x64-setup.exe#/ani-desk-setup.exe",
      "hash": "PLACEHOLDER_SHA256_NSIS"
    }
  },
  "installer": {
    "script": "Start-Process \"$dir\\ani-desk-setup.exe\" -ArgumentList '/S' -Wait"
  },
  "uninstaller": {
    "script": "if (Test-Path \"$env:LOCALAPPDATA\\Programs\\ani-desk\\uninstall.exe\") { Start-Process \"$env:LOCALAPPDATA\\Programs\\ani-desk\\uninstall.exe\" -ArgumentList '/S' -Wait }"
  },
  "env_set": {
    "ANI_DESK_PLAYER": "$dir\\tools\\mpv\\mpv.exe"
  },
  "suggest": {
    "mpv": "mpv"
  },
  "notes": [
    "ani-desk has been installed.",
    "Launch ani-desk from the Start Menu.",
    "The v1.0 Windows installer is unsigned and may trigger SmartScreen on first launch.",
    "Install mpv for fallback playback if it is not already available."
  ],
  "checkver": {
    "github": "https://github.com/silent9669/ani-desk"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/silent9669/ani-desk/releases/download/v$version/ani-desk_$version_x64-setup.exe#/ani-desk-setup.exe",
        "hash": {
          "url": "$url.sha256"
        }
      }
    }
  }
}
